	(text "FIXME\nFUck this basic buck shit\nif I need so much cap, give me a modern switcher with smaller coil too?\npay for the buck, not for stupid bulk caps?"
		(exclude_from_sim no)
		(at 102.362 102.616 0)
		(effects
			(font
				(size 2.54 2.54)
			)
			(justify left)
