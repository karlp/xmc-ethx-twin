	)
	(text "This has quite a bit less capacitance on both\nin/out than requested. \"It's probably fine\"\nWorst case, you have to use USB to power this\nboard, or get power from the pi header..."
		(exclude_from_sim no)
		(at 141.732 157.226 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "8c3eafe6-4029-471b-9ef7-1ed484e4bc65")
	)
