	(text "FXL1040 looks good."
		(exclude_from_sim no)
		(at 217.17 138.684 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c172a3e8-58d3-4f32-8f53-7218a5701961")
	)
	(text "There are _two_ 24V+ buck regulators in JLC basic.\nTPS5430, and XL1509.\nTPS54030 requires extensive compensation on output side to use ceramics.\nBoth of them really want \"a lot\" more cap than we can cheaply give them on jlc basic\nAnd for test boards, not interested in putting down alus and paying the line item charge."
		(exclude_from_sim no)
		(at 194.818 156.718 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "c6fc8865-328e-447a-aa1d-e95cb6638a70")
	)
	(text "Careful!\nIt's in jlc basic, so it's cheap, but read the ds!\nyou need compensation to use all ceramics!"
		(exclude_from_sim no)
		(at 125.984 254 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "e260d477-2e92-4341-9024-bcfd82c13dfa")
	)
